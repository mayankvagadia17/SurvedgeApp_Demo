<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical">

    <View
        android:layout_width="@dimen/_40sdp"
        android:layout_height="@dimen/_4sdp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/_12sdp"
        android:layout_marginBottom="@dimen/_5sdp"
        android:background="@drawable/bg_dropdown" />

    <ViewFlipper
        android:id="@+id/vf_code_manager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:inAnimation="@anim/slide_in_right"
        android:outAnimation="@anim/slide_out_left">

        <!-- Child 0: Select Code View -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_40sdp"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/_15sdp"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btn_add_code"
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:background="@drawable/bg_close"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_add"
                    app:tint="@null"
                    android:scaleType="centerInside"
                    android:padding="@dimen/_6sdp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Select Code"
                    android:textColor="@color/code_header_text"
                    android:textSize="@dimen/_12ssp"
                    android:textStyle="bold"/>

                <ImageButton
                    android:id="@+id/btn_close"
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:background="@drawable/bg_close"
                    android:layout_gravity="center_vertical|end"
                    android:src="@drawable/ic_close"
                    app:tint="@null"
                    android:scaleType="centerInside"
                    android:padding="@dimen/_6sdp"/>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/_2sdp"
                android:layout_marginBottom="@dimen/_10sdp"
                android:background="@drawable/divider_horizontal" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:paddingHorizontal="@dimen/_10sdp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/_16sdp"
                    android:layout_height="@dimen/_16sdp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/code_search_hint" />

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:hint="Search"
                    android:inputType="text"
                    android:paddingVertical="@dimen/_10sdp"
                    android:paddingHorizontal="@dimen/_14sdp"
                    android:textSize="@dimen/_12ssp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_codes"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/_16sdp" />

        </LinearLayout>

        <!-- Child 1: Add Code View -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/ll_header"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_40sdp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/_15sdp">

                <ImageButton
                    android:id="@+id/btn_back_to_select"
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:layout_gravity="center_vertical"
                    android:background="@drawable/bg_close"
                    android:padding="@dimen/_6sdp"
                    android:scaleType="centerInside"
                    android:src="@drawable/back_arraw"
                    app:tint="@null" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="New Code"
                    android:textColor="@color/code_header_text"
                    android:textSize="@dimen/_12ssp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_close_add_code"
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:layout_gravity="center_vertical|end"
                    android:background="@drawable/bg_close"
                    android:padding="@dimen/_6sdp"
                    android:visibility="invisible"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_close"
                    app:tint="@null" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/_2sdp"
                android:layout_marginBottom="@dimen/_10sdp"
                android:background="@drawable/divider_horizontal" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/_15sdp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_6sdp"
                        android:text="Code Name"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/_10ssp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_code_name"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginBottom="@dimen/_4sdp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Enter code name"
                        android:inputType="text"
                        android:maxLength="5"
                        android:textAllCaps="true"
                        android:paddingHorizontal="@dimen/_15sdp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="@dimen/_12ssp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_10sdp"
                        android:text="Choose a unique name for the collection. You can link it to projects later."
                        android:textColor="@color/neutral_dark"
                        android:textSize="@dimen/_8ssp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_6sdp"
                        android:text="Type"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/_10ssp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinner_code_type"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginBottom="@dimen/_10sdp"
                        android:background="@drawable/bg_input_field"
                        android:paddingHorizontal="@dimen/_15sdp"
                        android:theme="@style/Theme.Material3.Light" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/_6sdp"
                        android:text="Code Description"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/_10ssp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/et_code_desc"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginBottom="@dimen/_15sdp"
                        android:background="@drawable/bg_input_field"
                        android:hint="Enter code desc."
                        android:inputType="text"
                        android:paddingHorizontal="@dimen/_15sdp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="@dimen/_12ssp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_add"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_42sdp"
                        android:background="@drawable/bg_button_save"
                        android:fontFamily="@font/manrope_semibold"
                        android:text="Save"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_14ssp"
                        android:textStyle="bold"
                        app:backgroundTint="@null"
                        app:cornerRadius="@dimen/_12sdp" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </LinearLayout>

    </ViewFlipper>

</LinearLayout>
